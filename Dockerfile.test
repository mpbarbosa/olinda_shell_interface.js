# ── Test runner image for olinda_shell_interface.js ──────────────────────────
#
# Build and run:
#   docker build -f Dockerfile.test -t olinda_shell_interface-test .
#   docker run --rm -e CI=true olinda_shell_interface-test
#
# Run with coverage extracted to the host:
#   docker run --rm \
#     -e CI=true \
#     -v "$(pwd)/coverage:/app/coverage" \
#     olinda_shell_interface-test \
#     npm test -- --runInBand --coverage
#
# Or use the convenience script (recommended):
#   npm run test:docker
#   bash scripts/run-tests-docker.sh
#   bash scripts/run-tests-docker.sh -- --coverage
# ─────────────────────────────────────────────────────────────────────────────

FROM node:22-alpine

# Install system tools required by the test suite:
#   git  — npm ci clones the olinda_utils.js git+https dependency and must
#           run its `prepare` script (tsc); git is required for the clone.
#   bash — executor.test.ts explicitly invokes /bin/bash (shell: '/bin/bash') and
#           runs `bash -c "…"` commands; /bin/sh (ash) alone is not sufficient.
#   jq   — jq_wrapper.test.ts calls the real jq CLI binary; the module wraps jq
#           commands and the integration tests verify actual jq output.
RUN apk add --no-cache git bash jq

WORKDIR /app

# Copy dependency manifests first so this layer is cached between source changes.
COPY package.json package-lock.json ./

# Override NODE_ENV=production (the default in all official Node images) so that
# npm ci installs devDependencies (Jest, ts-jest, TypeScript, etc.).
#
# NOTE: --ignore-scripts is intentionally NOT used here. The olinda_utils.js
# production dependency has a `prepare` script that compiles its TypeScript source
# to dist/. Skipping it leaves the package without its built output, causing import
# failures in several test suites. Since the prepare script only runs `tsc`, it is
# safe to allow inside Alpine.
ENV NODE_ENV=test
RUN npm ci

# Copy the rest of the project after npm ci so source changes don't invalidate
# the dependency cache layer. .dockerignore controls what is excluded.
COPY . .

# Run the full Jest suite by default.
CMD ["npm", "test"]
